# Конфигурация приложения
# Скопируйте этот файл в .env и заполните значения

# Порт сервера
PORT=3000

# Секрет для сессий (замените на случайную строку)
SESSION_SECRET=change_this_to_a_random_secret_string

# SMTP настройки (заполняются через интерфейс настроек или здесь)
SMTP_HOST=mail.example.ru
SMTP_PORT=587
SMTP_USER=noreply@example.ru
SMTP_PASS=your_password
SMTP_FROM="Портфолио IS1C <noreply@example.ru>"

# Email менеджера для уведомлений
MANAGER_EMAIL=manager@example.ru

# Пароль менеджера по умолчанию (при первом запуске)
# ВНИМАНИЕ: после первого входа смените пароль в настройках!
DEFAULT_MANAGER_PASSWORD=Admin1234!
#рабочие настройки:
PORT=3000
SESSION_SECRET=is1c-portfolio-secret-2024-change-me
DEFAULT_MANAGER_PASSWORD=Admin1234!

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=portfolio
PG_USER=postgres
PG_PASSWORD=Admin1234!
Полностью рабочий env файл:
PORT=3000
SESSION_SECRET=is1c-portfolio-secret-2024-change-me
DEFAULT_MANAGER_PASSWORD=Admin1234!

# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=portfolio
PG_USER=postgres
PG_PASSWORD=Admin1234!

# ===== Active Directory (тестовый Samba AD) =====
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=DC=test,DC=local
LDAP_BIND_DN=CN=Administrator,CN=Users,DC=test,DC=local
LDAP_BIND_PASSWORD=Passw0rd


# Конфигурация приложения
# Скопируйте этот файл в .env и заполните значения

# Порт сервера
PORT=3000

# Секрет для сессий (замените на случайную строку)
SESSION_SECRET=change_this_to_a_random_secret_string

# SMTP настройки (заполняются через интерфейс настроек или здесь)
SMTP_HOST=mail.example.ru
SMTP_PORT=587
SMTP_USER=noreply@example.ru
SMTP_PASS=your_password
SMTP_FROM="Портфолио IS1C <noreply@example.ru>"

# Email менеджера для уведомлений
MANAGER_EMAIL=manager@example.ru

# Пароль менеджера по умолчанию (при первом запуске)
# ВНИМАНИЕ: после первого входа смените пароль в настройках!
DEFAULT_MANAGER_PASSWORD=1234
